<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.Dark">
        <activity
            android:name=".Register"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="false" />
        <activity
            android:name=".Login"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".HomeActivity"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="true" />

        <activity android:name=".AddCategoryActivity"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="true" />

        <activity android:name=".AddExpenseActivity"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="true" />

        <activity android:name=".BudgetGoalsActivity"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="true" />

        <activity android:name=".ViewExpensesActivity"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="true" />

        <activity android:name=".CategoryTotalsActivity"
            android:theme="@style/Theme.Material3.Dark.NoActionBar"
            android:exported="true" />


        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Authentification1">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>